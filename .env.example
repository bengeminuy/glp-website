# =============================================================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. Never commit real secrets.
# =============================================================================

# --- Database ----------------------------------------------------------------
# Postgres connection string. For local dev, run a Postgres container or use a
# free Neon project: https://neon.tech
DATABASE_URL=postgres://user:password@localhost:5432/glp_website

# --- Better Auth -------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=
# Public base URL of the app. http://localhost:3000 for dev.
BETTER_AUTH_URL=http://localhost:3000

# --- PHI Encryption ----------------------------------------------------------
# Used to encrypt questionnaire answers at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# IMPORTANT: rotating this key invalidates existing encrypted rows. Plan a
# re-encryption migration before rotating in production.
ENCRYPTION_KEY=

# --- Stripe (placeholder until payment is wired up) --------------------------
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret from `stripe listen --forward-to .../api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=
